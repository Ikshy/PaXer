# --- App ---
APP_ENV=development
SECRET_KEY=changeme-use-a-long-random-string

# --- Synthetic Generator ---
SYNTH_SEED=42
SYNTH_NUM_IMAGES=10
SYNTH_OUTPUT_DIR=data/samples
