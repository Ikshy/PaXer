# .dockerignore
# Keeps the Docker build context lean — only copy what the image needs.

# Version control
.git/
.github/

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
coverage.xml
htmlcov/

# Frontend build artifacts and deps
frontend/node_modules/
frontend/dist/
frontend/.env.local

# Data — generated samples are copied explicitly when needed
data/store/
data/samples/images/

# Test / CI artifacts
.coverage

# Env files with secrets
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Docs
docs/
*.md
