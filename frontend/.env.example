# Copy to .env.local for local dev. Never commit .env.local.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# API base URL — leave empty to use Vite dev-server proxy (recommended for local dev)
VITE_API_BASE=

# Set to your deployed backend URL in production:
# VITE_API_BASE=https://api.your-cthmp-domain.example
